# ══════════════════════════════════════════════════
# Javirs — Production Environment Template
# ══════════════════════════════════════════════════
# Copy this to .env.prod and fill in real values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ══════════════════════════════════════════════════

# ── Docker / Database ─────────────────────────
POSTGRES_USER=javirs
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=javirs
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ── Authentication ────────────────────────────
# Generate with: openssl rand -base64 64
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=GENERATE_ME
JWT_SECRET=GENERATE_ME
JWT_REFRESH_SECRET=GENERATE_ME

# ── AI / LLM APIs ────────────────────────────
OPENAI_API_KEY=sk-your-production-key
ANTHROPIC_API_KEY=sk-ant-your-production-key
GEMINI_API_KEY=your-production-gemini-key

# ── Safe Chat & Rate Limiting ─────────────────
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=999
SAFE_CHAT_MODEL=gemini-2.5-flash
UPLOAD_MAX_SIZE=5242880

# ── External Services ─────────────────────────
RESEND_API_KEY=re_your-production-key
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=javirs-uploads

# ── App URLs ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api
