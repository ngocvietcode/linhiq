generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  passwordHash    String?
  googleId        String?             @unique
  name            String
  avatarUrl       String?
  role            Role                @default(STUDENT)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  isActive        Boolean             @default(true)
  chatSessions    ChatSession[]
  keyTermsEarned  KeyTermEarned[]
  childLinks      ParentChild[]       @relation("ChildLinks")
  parentLinks     ParentChild[]       @relation("ParentLinks")
  quizAttempts    QuizAttempt[]
  slideDecks      SlideDeckSnapshot[]
  studentProfile  StudentProfile?
  studySessions   StudySession[]
  readerBookmarks ReaderBookmark[]
  readerNotes     ReaderNote[]

  @@index([email])
  @@index([role])
  @@index([googleId])
}

model StudentProfile {
  id          String              @id @default(cuid())
  userId      String              @unique
  curriculum  Curriculum          @default(IGCSE)
  timezone    String              @default("Asia/Ho_Chi_Minh")
  studyGoal   Int                 @default(60)
  streakDays  Int                 @default(0)
  lastStudyAt DateTime?
  updatedAt   DateTime            @updatedAt
  diagnostics DiagnosticResult[]
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments SubjectEnrollment[]
}

model ParentChild {
  id       String   @id @default(cuid())
  parentId String
  childId  String
  linkedAt DateTime @default(now())
  child    User     @relation("ChildLinks", fields: [childId], references: [id])
  parent   User     @relation("ParentLinks", fields: [parentId], references: [id])

  @@unique([parentId, childId])
}

model Subject {
  id           String              @id @default(cuid())
  name         String
  description  String?
  iconEmoji    String              @default("📚")
  isActive     Boolean             @default(true)
  nameVi       String?
  orderIndex   Int                 @default(0)
  curriculum   Curriculum
  bookVolumes  BookVolume[]
  chatSessions ChatSession[]
  documents    Document[]
  quizAttempts QuizAttempt[]
  enrollments  SubjectEnrollment[]
  topics       Topic[]
  Unit         Unit[]

  @@unique([name, curriculum])
  @@index([curriculum])
}

model Topic {
  id           String               @id @default(cuid())
  subjectId    String
  name         String
  orderIndex   Int                  @default(0)
  description  String?
  nameVi       String?
  unitId       String?
  pageTopics   BookPageTopic[]
  diagnostics  DiagnosticQuestion[]
  chunks       DocumentChunk[]
  quizAttempts QuizAttempt[]
  subject      Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  Unit         Unit?                @relation(fields: [unitId], references: [id])
  progress     TopicProgress[]

  @@unique([subjectId, name])
  @@index([subjectId])
  @@index([unitId])
}

model SubjectEnrollment {
  id         String         @id @default(cuid())
  profileId  String
  subjectId  String
  enrolledAt DateTime       @default(now())
  profile    StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject    Subject        @relation(fields: [subjectId], references: [id])

  @@unique([profileId, subjectId])
}

model Document {
  id          String          @id @default(cuid())
  subjectId   String
  title       String
  filePath    String?
  createdAt   DateTime        @default(now())
  fileSize    Int?
  isProcessed Boolean         @default(false)
  pageCount   Int?
  processedAt DateTime?
  sourceType  SourceType
  bookVolume  BookVolume?
  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chunks      DocumentChunk[]

  @@index([subjectId])
  @@index([isProcessed])
}

model DocumentChunk {
  id         String                 @id @default(cuid())
  documentId String
  topicId    String?
  content    String
  metadata   Json?
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())
  chunkIndex Int
  keywords   String[]
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  topic      Topic?                 @relation(fields: [topicId], references: [id])

  @@index([documentId])
  @@index([topicId])
}

model BookVolume {
  id         String           @id @default(cuid())
  subjectId  String
  title      String
  shortTitle String
  bookType   BookType
  isDefault  Boolean          @default(false)
  coverColor String?
  orderIndex Int              @default(0)
  totalPages Int?
  pagesDir   String?
  documentId String?          @unique
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  pageTopics BookPageTopic[]
  bookmarks  ReaderBookmark[]
  notes      ReaderNote[]
  document   Document?        @relation(fields: [documentId], references: [id])
  subject    Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([isDefault])
}

model BookPageTopic {
  id           String     @id @default(cuid())
  bookVolumeId String
  pageNumber   Int
  topicId      String?
  chapterName  String?
  bookVolume   BookVolume @relation(fields: [bookVolumeId], references: [id], onDelete: Cascade)
  topic        Topic?     @relation(fields: [topicId], references: [id])

  @@unique([bookVolumeId, pageNumber])
  @@index([bookVolumeId])
  @@index([topicId])
}

model ReaderBookmark {
  id           String     @id @default(cuid())
  userId       String
  bookVolumeId String
  pageNumber   Int
  label        String?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookVolume   BookVolume @relation(fields: [bookVolumeId], references: [id], onDelete: Cascade)

  @@unique([userId, bookVolumeId, pageNumber])
  @@index([userId, bookVolumeId])
}

model ReaderNote {
  id           String     @id @default(cuid())
  userId       String
  bookVolumeId String
  pageNumber   Int
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookVolume   BookVolume @relation(fields: [bookVolumeId], references: [id], onDelete: Cascade)

  @@index([userId, bookVolumeId])
  @@index([userId, bookVolumeId, pageNumber])
}

model ChatSession {
  id         String            @id @default(cuid())
  userId     String
  subjectId  String?
  title      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  endedAt    DateTime?
  hintLevel  HintLevel         @default(L1)
  mode       ChatMode          @default(SUBJECT)
  messages   ChatMessage[]
  subject    Subject?          @relation(fields: [subjectId], references: [id])
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicStats SessionTopicStat?

  @@index([userId])
  @@index([subjectId])
  @@index([createdAt])
}

model ChatMessage {
  id            String         @id @default(cuid())
  sessionId     String
  role          String
  content       String
  createdAt     DateTime       @default(now())
  hintLevel     HintLevel?
  imageUrl      String?
  modelUsed     String?
  ragSources    String[]
  safeCategory  TopicCategory?
  tokensUsed    Int?
  wasRedirected Boolean        @default(false)
  session       ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String?
  durationMin Int
  date        DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model TopicProgress {
  id             String    @id @default(cuid())
  userId         String
  topicId        String
  masteryLevel   Float     @default(0)
  questionsAsked Int       @default(0)
  correctAnswers Int       @default(0)
  lastStudiedAt  DateTime?
  updatedAt      DateTime  @updatedAt
  topic          Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
}

model KeyTermEarned {
  id        String   @id @default(cuid())
  userId    String
  term      String
  subjectId String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subjectId])
}

model DiagnosticQuestion {
  id          String             @id @default(cuid())
  topicId     String
  question    String
  options     Json
  correct     Int
  explanation String?
  topic       Topic              @relation(fields: [topicId], references: [id])
  results     DiagnosticResult[]
}

model DiagnosticResult {
  id          String             @id @default(cuid())
  profileId   String
  questionId  String
  answeredIdx Int
  isCorrect   Boolean
  createdAt   DateTime           @default(now())
  profile     StudentProfile     @relation(fields: [profileId], references: [id])
  question    DiagnosticQuestion @relation(fields: [questionId], references: [id])
}

model WeeklyTopicStat {
  id         String   @id @default(cuid())
  userId     String
  weekStart  DateTime
  academic   Int      @default(0)
  general    Int      @default(0)
  hobbies    Int      @default(0)
  life       Int      @default(0)
  redirected Int      @default(0)
  totalMsg   Int      @default(0)

  @@unique([userId, weekStart])
  @@index([weekStart])
}

model SessionTopicStat {
  id         String      @id @default(cuid())
  sessionId  String      @unique
  academic   Int         @default(0)
  general    Int         @default(0)
  hobbies    Int         @default(0)
  life       Int         @default(0)
  redirected Int         @default(0)
  totalMsg   Int         @default(0)
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id                String   @id @default("global")
  updatedAt         DateTime @updatedAt
  maintenanceMode   Boolean  @default(false)
  onboardingEnabled Boolean  @default(true)
  rateLimitFree     Int      @default(10)
  rateLimitPro      Int      @default(999)
  safeChatEnabled   Boolean  @default(true)
  safeChatModel     String   @default("gemini-2.5-flash")
  complexQueryModel String   @default("gemini-2.5-pro")
  embeddingModel    String   @default("gemini-embedding-001")
  simpleQueryModel  String   @default("gemini-2.5-flash")
  liteLlmApiKey     String?
  liteLlmUrl        String?
  openChatPrompt    String?
  maxTokensOpenChat Int      @default(300)
  maxTokensSocratic Int      @default(1024)
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model QuizAttempt {
  id          String         @id @default(cuid())
  userId      String
  subjectId   String
  quizType    QuizType
  topicId     String?
  score       Int            @default(0)
  total       Int            @default(0)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  unitId      String?
  subject     Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic       Topic?         @relation(fields: [topicId], references: [id])
  Unit        Unit?          @relation(fields: [unitId], references: [id])
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]

  @@index([userId])
  @@index([topicId])
  @@index([unitId])
}

model QuizQuestion {
  id            String      @id @default(cuid())
  attemptId     String
  topicId       String?
  orderIndex    Int
  question      String
  options       Json
  correctAnswer String
  explanation   String
  studentAnswer String?
  isCorrect     Boolean?
  attempt       QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model Unit {
  id          String        @id
  subjectId   String
  name        String
  orderIndex  Int           @default(0)
  description String?
  QuizAttempt QuizAttempt[]
  Topic       Topic[]
  Subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, name])
  @@index([subjectId])
}

enum Role {
  STUDENT
  PARENT
  ADMIN
}

enum Curriculum {
  IGCSE
  A_LEVEL
  THPT_VN
  IB
  AP
}

enum SourceType {
  TEXTBOOK
  MARK_SCHEME
  PAST_PAPER
  SYLLABUS
}

enum BookType {
  COURSEBOOK
  WORKBOOK
  TEACHER_GUIDE
  PAST_PAPER
  SYLLABUS
  REVISION_GUIDE
}

enum HintLevel {
  L1
  L2
  L3
  L4
  L5
}

enum ChatMode {
  SUBJECT
  OPEN
}

enum TopicCategory {
  ACADEMIC
  GENERAL
  HOBBIES
  LIFE
  EMOTIONAL
  MATURE_SOFT
  AGE_BOUNDARY
  HARMFUL
}

enum QuizType {
  TOPIC
  UNIT
}

model SlideDeckSnapshot {
  id           String   @id @default(cuid())
  userId       String
  subjectId    String?
  bookVolumeId String?
  topicId      String?
  pageStart    Int?
  pageEnd      Int?
  title        String
  language     String   @default("vi")
  depth        String   @default("standard")
  deckJson     Json
  tokenUsage   Int?
  durationMs   Int?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([bookVolumeId])
}
